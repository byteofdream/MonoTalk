# MonoTalk - Основной .htaccess
# Для InfinityFree: если проект в подпапке, добавьте RewriteBase

# Защита includes
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Кодировка
AddDefaultCharset UTF-8

# Error pages
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php
